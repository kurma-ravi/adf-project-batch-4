		{
			"name": "[concat(parameters('factoryName'), '/DFSCD2')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "DelimitedTextSCD2CSV",
								"type": "DatasetReference"
							},
							"name": "sourceSCD2csv"
						},
						{
							"dataset": {
								"referenceName": "AzureSqlTableDBSCD2",
								"type": "DatasetReference"
							},
							"name": "sourceDB"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "AzureSqlTableDB_SCD2_INSERT",
								"type": "DatasetReference"
							},
							"name": "INSERTsink"
						},
						{
							"dataset": {
								"referenceName": "AzureSqlTableSCD2_UPDATE",
								"type": "DatasetReference"
							},
							"name": "UPDATEsink"
						}
					],
					"transformations": [
						{
							"name": "srcderivedColumnHC"
						},
						{
							"name": "DestderivedColumnHC"
						},
						{
							"name": "SRCexistsHC"
						},
						{
							"name": "IsActivederivedColumn"
						},
						{
							"name": "Insertselect"
						},
						{
							"name": "DBexists"
						},
						{
							"name": "DBexistsHC"
						},
						{
							"name": "IsActivederivedColumnDB"
						},
						{
							"name": "DBalterRow"
						},
						{
							"name": "DBselectCols"
						}
					],
					"scriptLines": [
						"source(output(",
						"          Employee_ID as integer,",
						"          First_Name as string,",
						"          Salary as integer,",
						"          Location as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     partitionBy('hash', 1)) ~> sourceSCD2csv",
						"source(output(",
						"          SurrKey as integer,",
						"          Emp_ID as integer,",
						"          FName as string,",
						"          Salary as integer,",
						"          Loc as string,",
						"          Is_Active as integer",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     isolationLevel: 'READ_UNCOMMITTED',",
						"     format: 'table',",
						"     partitionBy('hash', 1)) ~> sourceDB",
						"sourceSCD2csv derive(Hashcode = md5(Employee_ID,First_Name,Salary,Location),",
						"     partitionBy('hash', 1)) ~> srcderivedColumnHC",
						"sourceDB derive(Hashcode = md5(Emp_ID,FName,Salary,Loc),",
						"     partitionBy('hash', 1)) ~> DestderivedColumnHC",
						"srcderivedColumnHC, DestderivedColumnHC exists(srcderivedColumnHC@Hashcode == DestderivedColumnHC@Hashcode,",
						"     negate:true,",
						"     broadcast: 'auto')~> SRCexistsHC",
						"SRCexistsHC derive(Is_Active = 1,",
						"     partitionBy('hash', 1)) ~> IsActivederivedColumn",
						"IsActivederivedColumn select(mapColumn(",
						"          Employee_ID,",
						"          First_Name,",
						"          Salary,",
						"          Location,",
						"          Is_Active",
						"     ),",
						"     partitionBy('hash', 1),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> Insertselect",
						"DestderivedColumnHC, srcderivedColumnHC exists(Emp_ID == Employee_ID,",
						"     negate:false,",
						"     broadcast: 'auto')~> DBexists",
						"DBexists, SRCexistsHC exists(DestderivedColumnHC@Hashcode == srcderivedColumnHC@Hashcode,",
						"     negate:true,",
						"     partitionBy('hash', 1),",
						"     broadcast: 'auto')~> DBexistsHC",
						"DBexistsHC derive(Is_Active = 0,",
						"     partitionBy('hash', 1)) ~> IsActivederivedColumnDB",
						"IsActivederivedColumnDB alterRow(updateIf(true()),",
						"     partitionBy('hash', 1)) ~> DBalterRow",
						"DBalterRow select(mapColumn(",
						"          SurrKey,",
						"          Emp_ID,",
						"          FName,",
						"          Salary,",
						"          Loc,",
						"          Is_Active",
						"     ),",
						"     partitionBy('hash', 1),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> DBselectCols",
						"Insertselect sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     input(",
						"          SurrKey as integer,",
						"          Emp_ID as integer,",
						"          FName as string,",
						"          Salary as integer,",
						"          Loc as string,",
						"          Is_Active as integer",
						"     ),",
						"     deletable:false,",
						"     insertable:true,",
						"     updateable:false,",
						"     upsertable:false,",
						"     format: 'table',",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     errorHandlingOption: 'stopOnFirstError',",
						"     mapColumn(",
						"          Emp_ID = Employee_ID,",
						"          FName = First_Name,",
						"          Salary,",
						"          Loc = Location,",
						"          Is_Active",
						"     ),",
						"     partitionBy('hash', 1)) ~> INSERTsink",
						"DBselectCols sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     input(",
						"          SurrKey as integer,",
						"          Emp_ID as integer,",
						"          FName as string,",
						"          Salary as integer,",
						"          Loc as string,",
						"          Is_Active as integer",
						"     ),",
						"     deletable:false,",
						"     insertable:false,",
						"     updateable:true,",
						"     upsertable:false,",
						"     keys:['SurrKey'],",
						"     format: 'table',",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true,",
						"     errorHandlingOption: 'stopOnFirstError',",
						"     partitionBy('hash', 1)) ~> UPDATEsink"
					]
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/DataFlowActivity')]",
			"type": "Microsoft.DataFactory/factories/dataflows",
			"apiVersion": "2018-06-01",
			"properties": {
				"type": "MappingDataFlow",
				"typeProperties": {
					"sources": [
						{
							"dataset": {
								"referenceName": "DS_salesfileOnly_src",
								"type": "DatasetReference"
							},
							"name": "sourceSalesFile"
						}
					],
					"sinks": [
						{
							"dataset": {
								"referenceName": "DS_sinkfile",
								"type": "DatasetReference"
							},
							"name": "sinkFile"
						}
					],
					"transformations": [
						{
							"name": "selectColumns"
						},
						{
							"name": "filterInvoiceNo"
						},
						{
							"name": "splitCountryWise"
						},
						{
							"name": "aggregateOrder"
						}
					],
					"scriptLines": [
						"source(output(",
						"          InvoiceNo as string,",
						"          StockCode as string,",
						"          Description as string,",
						"          Quantity as short,",
						"          InvoiceDate as timestamp,",
						"          UnitPrice as double,",
						"          CustomerID as double,",
						"          Country as string",
						"     ),",
						"     allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     ignoreNoFilesFound: false,",
						"     partitionBy('hash', 1)) ~> sourceSalesFile",
						"sourceSalesFile select(mapColumn(",
						"          InvoiceNo,",
						"          Description,",
						"          Quantity,",
						"          InvoiceDate,",
						"          UnitPrice,",
						"          CustomerID,",
						"          Country",
						"     ),",
						"     partitionBy('hash', 1),",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> selectColumns",
						"selectColumns filter(InvoiceNo!='537669',",
						"     partitionBy('hash', 1)) ~> filterInvoiceNo",
						"filterInvoiceNo split(Country=='United Kingdom',",
						"     Country=='Germany',",
						"     Country=='Australia',",
						"     disjoint: false,",
						"     partitionBy('hash', 1)) ~> splitCountryWise@(UK, Germany, Australia, Other)",
						"splitCountryWise@UK aggregate(groupBy(InvoiceNo),",
						"     UnitPrice = sum(UnitPrice),",
						"     partitionBy('hash', 1)) ~> aggregateOrder",
						"aggregateOrder sink(allowSchemaDrift: true,",
						"     validateSchema: false,",
						"     umask: 0022,",
						"     preCommands: [],",
						"     postCommands: [],",
						"     skipDuplicateMapInputs: true,",
						"     skipDuplicateMapOutputs: true) ~> sinkFile"
					]
				}
			},
			"dependsOn": []
		},
